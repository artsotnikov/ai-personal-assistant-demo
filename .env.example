# =============================================
# AI Personal Assistant — Environment Variables
# =============================================
# Скопируйте этот файл как .env и заполните значения:
#   cp .env.example .env

# --- Database (PostgreSQL with pgvector extension) ---
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# --- Base URL (публичный адрес приложения) ---
BASE_URL=https://your-domain.com

# --- Auth ---
SESSION_SECRET=your-random-session-secret-here
WEBHOOK_SECRET=your-webhook-secret

# --- AI Providers (минимум один обязателен) ---
# Вариант 1: Antigravity Manager (OpenAI-совместимый шлюз)
ANTIGRAVITY_URL=https://your-antigravity-server/antigravity-api/v1
ANTIGRAVITY_API_KEY=sk-your-antigravity-key

# Вариант 2: OpenRouter (универсальный шлюз к разным моделям)
OPENROUTER_API_KEY=sk-or-v1-your-key

# Вариант 3: OpenAI напрямую
OPENAI_API_KEY=sk-proj-your-key
# OPENAI_PROXY=http://user:pass@proxy:port  # Опционально: прокси для OpenAI

# Вариант 4: DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Вариант 5: Groq (быстрый inference для Llama/Mixtral)
# GROQ_API_KEY=gsk_your-groq-key

# Вариант 6: Произвольный OpenAI-совместимый API
# CUSTOM_API_KEY=sk-your-key
# CUSTOM_API_URL=http://your-server:8045/v1
# CUSTOM_DEFAULT_MODEL=model-name

# --- TickTick Integration (опционально) ---
# TICKTICK_CLIENT_ID=your-client-id
# TICKTICK_CLIENT_SECRET=your-client-secret

# --- Web Search (опционально) ---
# TAVILY_API_KEY=tvly-your-key
# JINA_API_KEY=jina_your-key

# --- Scraper Service (опционально) ---
# SCRAPER_SERVICE_URL=https://your-scraper.example.com

# --- Perplexity (AI-поиск, опционально) ---
# PERPLEXITY_API_KEY=pplx-your-key

# --- Web Push Notifications (опционально) ---
# Сгенерировать: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=your-public-key
# VAPID_PRIVATE_KEY=your-private-key
# VAPID_SUBJECT=mailto:your-email@example.com

# --- Google Calendar MCP (опционально) ---
# MCP_GOOGLE_CALENDAR_ENABLED=true
# Требует google-credentials.json и google-token.json в корне проекта

# --- Yandex Disk / Obsidian Bridge (опционально) ---
# Настраивается через UI приложения (Настройки → Obsidian Bridge)
# Токен Yandex Disk хранится в базе данных, а не здесь

# --- Server ---
# PORT=5000  # Порт приложения (по умолчанию 5000)
