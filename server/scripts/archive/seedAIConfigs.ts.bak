async function seed() {
    console.log('🌱 Заполнение таблицы ai_model_configs...\n');

    for (const cfg of configs) {
        try {
            await db.insert(aiModelConfigs)
                .values(cfg)
                .onConflictDoUpdate({
                    target: aiModelConfigs.taskType,
                    set: {
                        provider: cfg.provider,
                        model: cfg.model,
                        temperature: cfg.temperature,
                        maxTokens: cfg.maxTokens,
                        description: cfg.description,
                        systemPrompt: cfg.systemPrompt,
                        updatedAt: new Date(),
                    }
                });
            console.log(`✅ ${cfg.taskType}: ${cfg.provider}/${cfg.model}`);
        } catch (error) {
            console.error(`❌ ${cfg.taskType}:`, error);
        }
    }

    console.log('\n🎉 Seed завершён!');
    process.exit(0);
}

seed().catch(err => {
    console.error('Ошибка seed:', err);
    process.exit(1);
});
